{
  "dashboard": {
    "title": "APC Keyword Cache",
    "uid": "apc-keyword-cache",
    "tags": ["apc", "cache", "keyword"],
    "timezone": "browser",
    "schemaVersion": 39,
    "panels": [
      {
        "id": 1,
        "title": "Cache Hit Rate",
        "type": "stat",
        "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "sum(rate(apc_cache_hit_total[5m])) / (sum(rate(apc_cache_hit_total[5m])) + sum(rate(apc_cache_miss_total[5m])))",
            "legendFormat": "hit rate"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "orange", "value": 0.5},
                {"color": "green", "value": 0.8}
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "Cache Hits by Layer",
        "type": "barchart",
        "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "sum(rate(apc_cache_hit_total[5m])) by (layer)",
            "legendFormat": "{{layer}}"
          }
        ]
      },
      {
        "id": 3,
        "title": "Cache Hit vs Miss Rate",
        "type": "timeseries",
        "gridPos": {"x": 12, "y": 0, "w": 12, "h": 4},
        "targets": [
          {
            "expr": "sum(rate(apc_cache_hit_total[1m]))",
            "legendFormat": "hits"
          },
          {
            "expr": "sum(rate(apc_cache_miss_total[1m]))",
            "legendFormat": "misses"
          }
        ]
      },
      {
        "id": 4,
        "title": "Keyword Normalization Actions",
        "type": "timeseries",
        "gridPos": {"x": 0, "y": 4, "w": 8, "h": 6},
        "targets": [
          {
            "expr": "sum(rate(apc_kw_normalization_action_total[5m])) by (action)",
            "legendFormat": "{{action}}"
          }
        ]
      },
      {
        "id": 5,
        "title": "Normalization Latency (ms)",
        "type": "timeseries",
        "gridPos": {"x": 8, "y": 4, "w": 8, "h": 6},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(apc_kw_normalization_latency_ms_bucket[5m])) by (le))",
            "legendFormat": "p50"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(apc_kw_normalization_latency_ms_bucket[5m])) by (le))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(apc_kw_normalization_latency_ms_bucket[5m])) by (le))",
            "legendFormat": "p99"
          }
        ]
      },
      {
        "id": 6,
        "title": "kw_cache Drift Rate",
        "type": "timeseries",
        "gridPos": {"x": 16, "y": 4, "w": 8, "h": 6},
        "targets": [
          {
            "expr": "sum(rate(apc_kw_cache_drift_total{direction=\"changed\"}[5m])) / (sum(rate(apc_kw_cache_drift_total[5m])) + 0.001)",
            "legendFormat": "drift rate"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 0.05},
                {"color": "orange", "value": 0.15},
                {"color": "red", "value": 0.20}
              ]
            }
          }
        }
      },
      {
        "id": 7,
        "title": "Normalization Fallback Reasons",
        "type": "barchart",
        "gridPos": {"x": 0, "y": 10, "w": 8, "h": 5},
        "targets": [
          {
            "expr": "sum(rate(apc_kw_normalization_fallback_total[5m])) by (reason)",
            "legendFormat": "{{reason}}"
          }
        ]
      },
      {
        "id": 8,
        "title": "Keyword Index Size",
        "type": "gauge",
        "gridPos": {"x": 8, "y": 10, "w": 4, "h": 5},
        "targets": [
          {
            "expr": "apc_kw_index_size",
            "legendFormat": "keywords"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 1000},
                {"color": "orange", "value": 3000},
                {"color": "red", "value": 5000}
              ]
            }
          }
        }
      },
      {
        "id": 9,
        "title": "Near-Duplicate Keywords Detected",
        "type": "stat",
        "gridPos": {"x": 12, "y": 10, "w": 4, "h": 5},
        "targets": [
          {
            "expr": "sum(rate(apc_kw_near_duplicate_total[1h]))",
            "legendFormat": "near dup/h"
          }
        ]
      },
      {
        "id": 10,
        "title": "kw_cache Hit Rate",
        "type": "stat",
        "gridPos": {"x": 16, "y": 10, "w": 4, "h": 5},
        "targets": [
          {
            "expr": "sum(rate(apc_kw_cache_hit_total[5m])) / (sum(rate(apc_kw_cache_hit_total[5m])) + sum(rate(apc_cache_miss_total[5m])))",
            "legendFormat": "kw_cache hit rate"
          }
        ]
      }
    ]
  }
}
